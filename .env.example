# Variables de entorno del frontend (Vite).
# Copiar este archivo como ".env" y completar con los valores de tu proyecto
# de Supabase (Project Settings > API).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------
# Nota: la Edge Function "admin-users" (supabase/functions/admin-users)
# usa variables propias configuradas como secretos en Supabase, NO en este
# archivo: SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_ANON_KEY.
# Se configuran con:
#   supabase secrets set SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
# -----------------------------------------------------------------------
